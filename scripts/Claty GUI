local avatarCache    = {}
local selectedPlayer = nil
local playerBtns     = {}

local function getAvatar(userId, callback)
    if avatarCache[userId] then callback(avatarCache[userId]); return end
    task.spawn(function()
        local ok, url = pcall(function()
            return Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        end)
        if ok and url then avatarCache[userId] = url; callback(url) end
    end)
end

local function selectPlayer(plr)
    if not plr or not plr.Parent then return end
    selectedPlayer = plr
    TpNameBox.Text = plr.Name
    TpAvatarIcon.Image          = ""
    TpAvatarPlaceholder.Visible = true
    getAvatar(plr.UserId, function(url)
        if TpAvatarIcon and TpAvatarIcon.Parent and selectedPlayer == plr then
            TpAvatarIcon.Image          = url
            TpAvatarPlaceholder.Visible = false
        end
    end)
    for p, data in pairs(playerBtns) do
        local isSel = (p == plr)
        data.frame.BackgroundColor3 = isSel and Color3.fromRGB(28,90,50) or C.Row
        data.nameLbl.TextColor3     = isSel and Color3.new(1,1,1) or C.Text
    end
end

local function buildPlayerList()
    for _, child in ipairs(TpPlayerList:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    playerBtns = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            local isSel    = (selectedPlayer == plr)
            local btnFrame = Instance.new("Frame")
            btnFrame.Size             = UDim2.new(1, 0, 0, 46)
            btnFrame.BackgroundColor3 = isSel and Color3.fromRGB(28,90,50) or C.Row
            btnFrame.BorderSizePixel  = 0
            btnFrame.Parent           = TpPlayerList
            addCorner(btnFrame, UDim.new(0, 9))
            addStroke(btnFrame, C.Stroke, 1)

            local avatar = Instance.new("ImageLabel")
            avatar.Size             = UDim2.new(0, 42, 0, 42)
            avatar.Position         = UDim2.new(0, 2, 0.5, -21)
            avatar.BackgroundTransparency = 1
            avatar.Image            = ""
            avatar.ScaleType        = Enum.ScaleType.Fit
            avatar.ZIndex           = 1
            avatar.Parent           = btnFrame
            addCorner(avatar, UDim.new(0, 10))

            local avatarIcon = Instance.new("TextLabel")
            avatarIcon.Size             = UDim2.new(1, 0, 1, 0)
            avatarIcon.BackgroundTransparency = 1
            avatarIcon.TextColor3       = C.SubText
            avatarIcon.Font             = Enum.Font.GothamBold
            avatarIcon.TextSize         = 20
            avatarIcon.Text             = "👤"
            avatarIcon.ZIndex           = 2
            avatarIcon.Parent           = avatar

            getAvatar(plr.UserId, function(url)
                if avatar    and avatar.Parent    then avatar.Image       = url   end
                if avatarIcon and avatarIcon.Parent then avatarIcon.Visible = false end
            end)

            local sameNameIgnoreCase = plr.Name:lower() == plr.DisplayName:lower()
            local labelText = sameNameIgnoreCase
                and ("@" .. plr.Name)
                or  ("@" .. plr.Name .. "\n" .. plr.DisplayName)

            local nameLbl = Instance.new("TextLabel")
            nameLbl.Size             = UDim2.new(1, -50, 1, 0)
            nameLbl.Position         = UDim2.new(0, 47, 0, 0)
            nameLbl.BackgroundTransparency = 1
            nameLbl.TextColor3       = isSel and Color3.new(1,1,1) or C.Text
            nameLbl.Font             = Enum.Font.GothamBold
            nameLbl.TextSize         = 16
            nameLbl.Text             = labelText
            nameLbl.TextXAlignment   = Enum.TextXAlignment.Left
            nameLbl.TextYAlignment   = Enum.TextYAlignment.Center
            nameLbl.TextTruncate     = Enum.TextTruncate.AtEnd
            nameLbl.Parent           = btnFrame

            local hitBtn = Instance.new("TextButton")
            hitBtn.Size             = UDim2.new(1, 0, 1, 0)
            hitBtn.BackgroundTransparency = 1
            hitBtn.Text             = ""
            hitBtn.BorderSizePixel  = 0
            hitBtn.ZIndex           = 3
            hitBtn.Parent           = btnFrame
            hitBtn.MouseButton1Click:Connect(function() selectPlayer(plr) end)

            playerBtns[plr] = {frame=btnFrame, nameLbl=nameLbl}
        end
    end
end

buildPlayerList()
Players.PlayerAdded:Connect(buildPlayerList)
Players.PlayerRemoving:Connect(function() task.defer(buildPlayerList) end)

TpNameBox.FocusLost:Connect(function(enterPressed)
    if not enterPressed then return end
    local q = TpNameBox.Text:lower()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then
            if plr.Name:lower():find(q,1,true) or plr.DisplayName:lower():find(q,1,true) then
                selectPlayer(plr); break
            end
        end
    end
end)

TpToPlrBtn.MouseButton1Click:Connect(function()
    if not selectedPlayer or not selectedPlayer.Parent then
        local q = TpNameBox.Text:lower()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and (plr.Name:lower():find(q,1,true) or plr.DisplayName:lower():find(q,1,true)) then
                selectPlayer(plr); break
            end
        end
    end
    if not selectedPlayer then return end
    local myChar   = LocalPlayer.Character
    local targChar = selectedPlayer.Character
    if not myChar or not targChar then return end
    local myRoot   = myChar:FindFirstChild("HumanoidRootPart")
    local targRoot = targChar:FindFirstChild("HumanoidRootPart")
    if not myRoot or not targRoot then return end
    myRoot.CFrame = targRoot.CFrame * CFrame.new(0, 0, 4)
    TpToPlrBtn.BackgroundColor3 = Color3.fromRGB(26,78,46)
    task.delay(0.3, function() TpToPlrBtn.BackgroundColor3 = C.TabActive end)
end)

