-- ── Current Position Display ─────────────────────────────────────
do
    local CurrPosLabel = Instance.new("Frame")
    CurrPosLabel.Size             = UDim2.new(1, 0, 0, 18)
    CurrPosLabel.BackgroundTransparency = 1
    CurrPosLabel.LayoutOrder      = 1
    CurrPosLabel.Parent           = Page2

    local CurrPosText = Instance.new("TextLabel")
    CurrPosText.Size             = UDim2.new(1, -4, 1, 0)
    CurrPosText.Position         = UDim2.new(0, 4, 0, 0)
    CurrPosText.BackgroundTransparency = 1
    CurrPosText.TextColor3       = C.SubText
    CurrPosText.Font             = Enum.Font.GothamBold
    CurrPosText.TextSize         = 11
    CurrPosText.Text             = "CURRENT POSITION"
    CurrPosText.TextXAlignment   = Enum.TextXAlignment.Left
    CurrPosText.Parent           = CurrPosLabel

    local CurrRow = Instance.new("Frame")
    CurrRow.Size             = UDim2.new(1, 0, 0, 37)
    CurrRow.BackgroundTransparency = 1
    CurrRow.LayoutOrder      = 2
    CurrRow.Parent           = Page2

    local CurrLayout = Instance.new("UIListLayout")
    CurrLayout.FillDirection       = Enum.FillDirection.Horizontal
    CurrLayout.SortOrder           = Enum.SortOrder.LayoutOrder
    CurrLayout.Padding             = UDim.new(0, 6)
    CurrLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    CurrLayout.VerticalAlignment   = Enum.VerticalAlignment.Center
    CurrLayout.Parent              = CurrRow

    local currLabels = {}

    local function makeCurrBox(axisLabel, layoutOrder)
        local wrap = Instance.new("Frame")
        wrap.Size             = UDim2.new(0.333, -5, 1, 0)
        wrap.BackgroundColor3 = C.Input
        wrap.BorderSizePixel  = 0
        wrap.LayoutOrder      = layoutOrder
        wrap.Parent           = CurrRow
        addCorner(wrap, CORNER_S)
        addStroke(wrap, C.Stroke, 1)

        local axLbl = Instance.new("TextLabel")
        axLbl.Size             = UDim2.new(0, 22, 1, 0)
        axLbl.Position         = UDim2.new(0, 8, 0, 0)
        axLbl.BackgroundTransparency = 1
        axLbl.TextColor3       = C.SubText
        axLbl.Font             = Enum.Font.GothamBold
        axLbl.TextSize         = 12
        axLbl.Text             = axisLabel
        axLbl.Parent           = wrap

        local divider = Instance.new("Frame")
        divider.Size             = UDim2.new(0, 1, 0.55, 0)
        divider.Position         = UDim2.new(0, 26, 0.22, 0)
        divider.BackgroundColor3 = C.Stroke
        divider.BorderSizePixel  = 0
        divider.Parent           = wrap

        local valLbl = Instance.new("TextLabel")
        valLbl.Size             = UDim2.new(1, -34, 1, 0)
        valLbl.Position         = UDim2.new(0, 31, 0, 0)
        valLbl.BackgroundTransparency = 1
        valLbl.TextColor3       = Color3.fromRGB(40, 200, 90)
        valLbl.Font             = Enum.Font.GothamBold
        valLbl.TextSize         = 13
        valLbl.Text             = "0"
        valLbl.TextXAlignment   = Enum.TextXAlignment.Center
        valLbl.Parent           = wrap

        currLabels[axisLabel] = valLbl
    end

    makeCurrBox("X", 1); makeCurrBox("Y", 2); makeCurrBox("Z", 3)

    RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local pos = root.Position
        local axisVals = {X=pos.X, Y=pos.Y, Z=pos.Z}
        for axis, lbl in pairs(currLabels) do
            local val = axisVals[axis]
            lbl.Text       = tostring(math.floor(val*10+0.5)/10)
            lbl.TextColor3 = val >= 0 and Color3.fromRGB(40,200,90) or Color3.fromRGB(220,60,60)
        end
    end)
end

-- ── Target Coordinate Input + Teleport ───────────────────────────
local _copiedCoords = nil

do
    local TargPosLabel = Instance.new("Frame")
    TargPosLabel.Size             = UDim2.new(1, 0, 0, 18)
    TargPosLabel.BackgroundTransparency = 1
    TargPosLabel.LayoutOrder      = 3
    TargPosLabel.Parent           = Page2

    local TargPosText = Instance.new("TextLabel")
    TargPosText.Size             = UDim2.new(1, -4, 1, 0)
    TargPosText.Position         = UDim2.new(0, 4, 0, 0)
    TargPosText.BackgroundTransparency = 1
    TargPosText.TextColor3       = C.SubText
    TargPosText.Font             = Enum.Font.GothamBold
    TargPosText.TextSize         = 11
    TargPosText.Text             = "TARGET COORDINATES"
    TargPosText.TextXAlignment   = Enum.TextXAlignment.Left
    TargPosText.Parent           = TargPosLabel

    local TargRow = Instance.new("Frame")
    TargRow.Size             = UDim2.new(1, 0, 0, 37)
    TargRow.BackgroundTransparency = 1
    TargRow.LayoutOrder      = 4
    TargRow.Parent           = Page2

    local TargLayout = Instance.new("UIListLayout")
    TargLayout.FillDirection       = Enum.FillDirection.Horizontal
    TargLayout.SortOrder           = Enum.SortOrder.LayoutOrder
    TargLayout.Padding             = UDim.new(0, 6)
    TargLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    TargLayout.VerticalAlignment   = Enum.VerticalAlignment.Center
    TargLayout.Parent              = TargRow

    local targBoxes = {}

    local function makeTargBox(axisLabel, layoutOrder)
        local wrap = Instance.new("Frame")
        wrap.Size             = UDim2.new(0.333, -5, 1, 0)
        wrap.BackgroundColor3 = C.Input
        wrap.BorderSizePixel  = 0
        wrap.LayoutOrder      = layoutOrder
        wrap.Parent           = TargRow
        addCorner(wrap, CORNER_S)
        addStroke(wrap, C.Stroke, 1)

        local axLbl = Instance.new("TextLabel")
        axLbl.Size             = UDim2.new(0, 22, 1, 0)
        axLbl.Position         = UDim2.new(0, 8, 0, 0)
        axLbl.BackgroundTransparency = 1
        axLbl.TextColor3       = C.SubText
        axLbl.Font             = Enum.Font.GothamBold
        axLbl.TextSize         = 12
        axLbl.Text             = axisLabel
        axLbl.Parent           = wrap

        local divider = Instance.new("Frame")
        divider.Size             = UDim2.new(0, 1, 0.55, 0)
        divider.Position         = UDim2.new(0, 26, 0.22, 0)
        divider.BackgroundColor3 = C.Stroke
        divider.BorderSizePixel  = 0
        divider.Parent           = wrap

        local box = Instance.new("TextBox")
        box.Size             = UDim2.new(1, -34, 1, 0)
        box.Position         = UDim2.new(0, 31, 0, 0)
        box.BackgroundTransparency = 1
        box.TextColor3       = C.Text
        box.Font             = Enum.Font.GothamBold
        box.TextSize         = 13
        box.Text             = ""
        box.ClearTextOnFocus = false
        box.PlaceholderText  = "0"
        box.PlaceholderColor3 = C.SubText
        box.TextXAlignment   = Enum.TextXAlignment.Center
        box.Parent           = wrap

        targBoxes[axisLabel] = box
    end

    makeTargBox("X", 1); makeTargBox("Y", 2); makeTargBox("Z", 3)

    -- Teleport to target coords button
    local TeleportRow = Instance.new("Frame")
    TeleportRow.Size             = UDim2.new(1, 0, 0, 37)
    TeleportRow.BackgroundTransparency = 1
    TeleportRow.LayoutOrder      = 5
    TeleportRow.Parent           = Page2

    local TeleportBtn = Instance.new("TextButton")
    TeleportBtn.Size             = UDim2.new(1, 0, 1, 0)
    TeleportBtn.BackgroundColor3 = C.TabActive
    TeleportBtn.Text             = ""
    TeleportBtn.BorderSizePixel  = 0
    TeleportBtn.Parent           = TeleportRow
    addCorner(TeleportBtn, CORNER_S)
    addStroke(TeleportBtn, Color3.fromRGB(0, 100, 210), 1.5)

    local TeleportLbl = Instance.new("TextLabel")
    TeleportLbl.Size             = UDim2.new(1, 0, 1, 0)
    TeleportLbl.BackgroundTransparency = 1
    TeleportLbl.TextColor3       = Color3.new(1,1,1)
    TeleportLbl.Font             = Enum.Font.GothamBold
    TeleportLbl.TextSize         = 13
    TeleportLbl.Text             = "Teleport to Coordinates"
    TeleportLbl.Parent           = TeleportBtn

    TeleportBtn.MouseButton1Click:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local tx = tonumber(targBoxes["X"].Text) or root.Position.X
        local ty = tonumber(targBoxes["Y"].Text) or root.Position.Y
        local tz = tonumber(targBoxes["Z"].Text) or root.Position.Z
        root.CFrame = CFrame.new(tx, ty, tz)
        TweenService:Create(TeleportBtn, TweenInfo.new(0.08), {BackgroundColor3=Color3.fromRGB(0,90,180)}):Play()
        task.delay(0.2, function()
            TweenService:Create(TeleportBtn, TweenInfo.new(0.15), {BackgroundColor3=C.TabActive}):Play()
        end)
    end)

    -- Utility buttons row: Set Position / Write Copied / Copy Coords
    local BottomRow = Instance.new("Frame")
    BottomRow.Size             = UDim2.new(1, 0, 0, 37)
    BottomRow.BackgroundTransparency = 1
    BottomRow.LayoutOrder      = 6
    BottomRow.Parent           = Page2
    addListLayout(BottomRow, Enum.FillDirection.Horizontal, 6)

    local function makeTpBtn(label, order, onClick)
        local b = Instance.new("TextButton")
        b.Size             = UDim2.new(0.333, -4, 1, 0)
        b.BackgroundColor3 = C.Row
        b.Text             = ""
        b.BorderSizePixel  = 0
        b.LayoutOrder      = order
        b.Parent           = BottomRow
        addCorner(b, CORNER_S)
        addStroke(b, C.Stroke, 1)

        local lbl = Instance.new("TextLabel")
        lbl.Size             = UDim2.new(1, -6, 1, 0)
        lbl.Position         = UDim2.new(0, 3, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3       = C.Text
        lbl.Font             = Enum.Font.GothamBold
        lbl.TextSize         = 11
        lbl.Text             = label
        lbl.TextWrapped      = true
        lbl.Parent           = b

        b.MouseButton1Click:Connect(function() task.spawn(onClick, b, lbl) end)
        return b, lbl
    end

    makeTpBtn("Set Position", 1, function(b)
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local pos = root.Position
        targBoxes["X"].Text = tostring(math.floor(pos.X*10+0.5)/10)
        targBoxes["Y"].Text = tostring(math.floor(pos.Y*10+0.5)/10)
        targBoxes["Z"].Text = tostring(math.floor(pos.Z*10+0.5)/10)
        TweenService:Create(b, TweenInfo.new(0.08), {BackgroundColor3=Color3.fromRGB(26,78,46)}):Play()
        task.delay(0.2, function() TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3=C.Row}):Play() end)
    end)

    makeTpBtn("Write Copied", 2, function(b)
        if not _copiedCoords then return end
        task.defer(function()
            targBoxes["X"].Text = tostring(_copiedCoords.X)
            targBoxes["Y"].Text = tostring(_copiedCoords.Y)
            targBoxes["Z"].Text = tostring(_copiedCoords.Z)
        end)
        TweenService:Create(b, TweenInfo.new(0.08), {BackgroundColor3=Color3.fromRGB(26,78,46)}):Play()
        task.delay(0.2, function() TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3=C.Row}):Play() end)
    end)

    makeTpBtn("Copy Coords", 3, function(b, lbl)
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local pos = root.Position
        local rx = math.floor(pos.X*10+0.5)/10
        local ry = math.floor(pos.Y*10+0.5)/10
        local rz = math.floor(pos.Z*10+0.5)/10
        _copiedCoords = {X=rx, Y=ry, Z=rz}
        pcall(setclipboard, string.format("%.1f, %.1f, %.1f", pos.X, pos.Y, pos.Z))
        lbl.Text = "Copied!"
        TweenService:Create(b, TweenInfo.new(0.08), {BackgroundColor3=Color3.fromRGB(26,78,46)}):Play()
        task.delay(1.2, function()
            lbl.Text = "Copy Coords"
            TweenService:Create(b, TweenInfo.new(0.15), {BackgroundColor3=C.Row}):Play()
        end)
    end)
end

