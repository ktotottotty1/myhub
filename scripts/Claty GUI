        TitleSep.Visible   = not isMinimized
        TitleCover.Visible = not isMinimized
        TweenService:Create(MainFrame, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {Size=targetSize}):Play()
    end)
end

-- ────────────────────────────────────────────────────────────────
--  FEATURE STATE FLAGS  (must be declared before CloseBtn and CharacterAdded)
-- ────────────────────────────────────────────────────────────────
