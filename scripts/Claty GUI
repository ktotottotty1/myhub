local P1BtnRow = Instance.new("Frame")
P1BtnRow.Size             = UDim2.new(1, 0, 0, 37)
P1BtnRow.BackgroundTransparency = 1
P1BtnRow.LayoutOrder      = ord + 1; ord = ord + 1
P1BtnRow.Parent           = Page1
addListLayout(P1BtnRow, Enum.FillDirection.Horizontal, 5)

local function makeP1Btn(label, order, col, onClick)
    local b = Instance.new("TextButton")
    b.Size             = UDim2.new(0.333, -4, 1, 0)
    b.BackgroundColor3 = col
    b.Text             = label
    b.TextColor3       = Color3.new(1, 1, 1)
    b.Font             = Enum.Font.GothamBold
    b.TextSize         = 11
    b.BorderSizePixel  = 0
    b.LayoutOrder      = order
    b.Parent           = P1BtnRow
    addCorner(b, CORNER_S)
    addStroke(b, C.Stroke, 1)
    local origCol = col
    b.MouseButton1Click:Connect(function()
        task.spawn(onClick)
        b.BackgroundColor3 = Color3.fromRGB(26, 78, 46)
        task.delay(0.22, function() b.BackgroundColor3 = origCol end)
    end)
end

makeP1Btn("Set Position", 1, Color3.fromRGB(0,110,210), function()
    local r = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not r then return end
    local p = r.Position
    invisBoxes["X"].Text = tostring(math.floor(p.X*10+0.5)/10)
    invisBoxes["Y"].Text = tostring(math.floor(p.Y*10+0.5)/10)
    invisBoxes["Z"].Text = tostring(math.floor(p.Z*10+0.5)/10)
end)

makeP1Btn("Copy Coords", 2, Color3.fromRGB(36,130,70), function()
    local r = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not r then return end
    local p = r.Position
    _copiedCoords = {
        X = math.floor(p.X*10+0.5)/10,
        Y = math.floor(p.Y*10+0.5)/10,
        Z = math.floor(p.Z*10+0.5)/10,
    }
    pcall(setclipboard, string.format("%.1f, %.1f, %.1f", p.X, p.Y, p.Z))
end)

makeP1Btn("Write Copied", 3, Color3.fromRGB(55,55,75), function()
    if not _copiedCoords then return end
    task.defer(function()
        invisBoxes["X"].Text = tostring(_copiedCoords.X)
        invisBoxes["Y"].Text = tostring(_copiedCoords.Y)
        invisBoxes["Z"].Text = tostring(_copiedCoords.Z)
    end)
end)

