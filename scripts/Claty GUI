local ord = 0

-- 1. Fly
ord = ord + 1
makeRow(Page1, "Fly", "toggle_box", ord, 50, "fly", function(isOn, box)
    flyIsActive = isOn
    if isOn then
        local v = tonumber(box.Text) or 50
        flySpeedValue = v
        if     settingsFlyType == "normal"  then enableNormalFly(v / 50)
        elseif settingsFlyType == "cframe"  then enableCFly(v)
        elseif settingsFlyType == "vehicle" then enableVehicleFly(v / 50)
        end
    else
        disableAllFly()
    end
end)

-- 2. Walk Speed
ord = ord + 1
makeRow(Page1, "Walk Speed", "toggle_box", ord, 50, "walkspeed", function(isOn, box)
    speedIsActive = isOn
    if isOn then
        local v = tonumber(box.Text) or 50
        walkSpeedValue = v
        if     settingsWalkSpeed == "normal" then applyNormalSpeed(v)
        elseif settingsWalkSpeed == "loop"   then enableLoopSpeed(v)
        end
    else
        disableLoopSpeed()
        applyNormalSpeed(16)
    end
end)

-- 3. Jump Power
ord = ord + 1
makeRow(Page1, "Jump Power", "toggle_box", ord, 80, "jumppower", function(isOn, box)
    jumpIsActive = isOn
    if isOn then
        local v = tonumber(box.Text) or 80
        jumpPowerValue = v
        if     settingsJumpPower == "normal" then applyNormalJump(v)
        elseif settingsJumpPower == "loop"   then enableLoopJump(v)
        end
    else
        disableLoopJump()
        applyNormalJump(50)
    end
end)

-- 4. Infinite Jump
