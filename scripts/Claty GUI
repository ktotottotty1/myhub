-- Forward declarations for panels (referenced inside CloseBtn handler)
local closeSettingsPanel
local closeSidePanel
local SidePanel
local SettingsPanel

-- ────────────────────────────────────────────────────────────────
--  CLOSE BUTTON
-- ────────────────────────────────────────────────────────────────
CloseBtn.MouseButton1Click:Connect(function()
    -- Disable all active features
    disableAllFly()
    disableAllSpeed()
    disableAllJump()
    disableInfJump()
    disableFlyjump()
    disableNoclip()
    disableTeleportTool()
    disableClickTp()
    disableAntiKill()
    disablePlayerESP()
    disableInvis()

    -- Reset flags so CharacterAdded does not re-enable features after death
    flyIsActive     = false
    speedIsActive   = false
    jumpIsActive    = false
    infJumpIsActive = false
    tpToolEnabled   = false
    invisEnabled    = false

    -- Disconnect CharacterAdded listener
    if charAddedConn then charAddedConn:Disconnect(); charAddedConn = nil end

    -- Close any open side panels
    if closeSettingsPanel then closeSettingsPanel() end
    if closeSidePanel     then closeSidePanel() end
    if SidePanel          then SidePanel.Visible    = false end
    if SettingsPanel      then SettingsPanel.Visible = false end

    -- Reset all toggle buttons to OFF state
    for _, state in pairs(featureStates) do
        pcall(function() if state.setOff then state.setOff() end end)
    end

    -- Animate close then destroy GUI
    TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
        Size     = UDim2.new(0, 390, 0, 0),
        Position = UDim2.new(MainFrame.Position.X.Scale, MainFrame.Position.X.Offset,
                             MainFrame.Position.Y.Scale, MainFrame.Position.Y.Offset + 342),
    }):Play()
    task.delay(0.22, function() ScreenGui:Destroy() end)
end)

