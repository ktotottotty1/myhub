-- ================================================================
--  Claty GUI  |  LocalScript → StarterPlayerScripts
--  Features: Fly, Walk Speed, Jump Power, Infinite Jump,
--            Noclip, Anti-Kill, Player ESP, Teleport Tool,
--            Click Teleport, Invisibility, Coordinate Teleport
-- ================================================================

-- ────────────────────────────────────────────────────────────────
--  SERVICES
-- ────────────────────────────────────────────────────────────────
local Players          = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")
local RunService       = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")
local IYMouse     = LocalPlayer:GetMouse()

-- ────────────────────────────────────────────────────────────────
--  COLOR PALETTE
-- ────────────────────────────────────────────────────────────────
local C = {
    BG          = Color3.fromRGB(22,  22,  28),
    TitleBar    = Color3.fromRGB(18,  18,  24),
    TabBar      = Color3.fromRGB(20,  20,  26),
    Section     = Color3.fromRGB(28,  28,  36),
    Row         = Color3.fromRGB(32,  32,  42),
    Input       = Color3.fromRGB(16,  16,  22),
    BtnOff      = Color3.fromRGB(42,  42,  55),
    BtnOn       = Color3.fromRGB(40, 165,  80),
    TabActive   = Color3.fromRGB(0,  130, 255),
    TabInactive = Color3.fromRGB(42,  42,  55),
    Stroke      = Color3.fromRGB(55,  55,  72),
    Text        = Color3.fromRGB(220, 222, 240),
    SubText     = Color3.fromRGB(130, 133, 160),
    BtnClose    = Color3.fromRGB(200,  55,  55),
    BtnMinimize = Color3.fromRGB(60,  200, 100),
    Separator   = Color3.fromRGB(45,  45,  60),
}

local CORNER   = UDim.new(0, 18)
local CORNER_S = UDim.new(0, 10)

-- ────────────────────────────────────────────────────────────────
--  UI HELPER FUNCTIONS
-- ────────────────────────────────────────────────────────────────
local function addCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = radius or CORNER
    c.Parent       = parent
    return c
end

local function addStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color           = color or C.Stroke
    s.Thickness       = thickness or 1.2
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent          = parent
    return s
end

local function addPadding(parent, top, bottom, left, right)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 0)
    p.PaddingBottom = UDim.new(0, bottom or 0)
    p.PaddingLeft   = UDim.new(0, left   or 0)
    p.PaddingRight  = UDim.new(0, right  or 0)
    p.Parent        = parent
    return p
end

local function addListLayout(parent, dir, pad, sortOrder)
    local l = Instance.new("UIListLayout")
    l.FillDirection = dir or Enum.FillDirection.Vertical
    l.SortOrder     = sortOrder or Enum.SortOrder.LayoutOrder
    l.Padding       = UDim.new(0, pad or 0)
    l.Parent        = parent
    return l
end

-- ────────────────────────────────────────────────────────────────
--  CHARACTER UTILITY FUNCTIONS
-- ────────────────────────────────────────────────────────────────
local function getHum(char)
    return char and (char:FindFirstChildOfClass("Humanoid") or char:FindFirstChildWhichIsA("Humanoid"))
end

local function getRoot(char)
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    return hum and hum.RootPart or nil
end

local function breakVelocity()
    if not LocalPlayer.Character then return end
    local zero = Vector3.new(0, 0, 0)
    for _, v in ipairs(LocalPlayer.Character:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Velocity    = zero
            v.RotVelocity = zero
        end
    end
end

-- ================================================================
--  FLY SYSTEM  (Normal / CFrame / Vehicle)
--  Source: Infinite Yield
-- ================================================================

-- Global fly state
local FLYING         = false
local currentFlyType = "none"   -- "none" | "normal" | "cframe" | "vehicle"
local iyflyspeed     = 1        -- multiplier for Normal/Vehicle fly
local CFspeed        = 50       -- speed for CFrame fly

-- Connections for Normal/Vehicle fly
local flyKeyDownConn = nil
local flyKeyUpConn   = nil
local flyBodyVel     = nil
local flyBodyGyro    = nil

-- Connection for CFrame fly
local CFloop = nil

local function disconnectNormalFlyKeys()
    if flyKeyDownConn then flyKeyDownConn:Disconnect(); flyKeyDownConn = nil end
    if flyKeyUpConn   then flyKeyUpConn:Disconnect();   flyKeyUpConn   = nil end
end

local function disableCFrameFly()
    if CFloop then CFloop:Disconnect(); CFloop = nil end
    local char = LocalPlayer.Character
    if char then
        local hum  = getHum(char)
        local head = char:FindFirstChild("Head")
        if hum  then hum.PlatformStand = false end
        if head then head.Anchored     = false end
    end
end

local function disableNormalFly()
    FLYING = false
    disconnectNormalFlyKeys()
    if flyBodyVel  and flyBodyVel.Parent  then flyBodyVel:Destroy()  end
    if flyBodyGyro and flyBodyGyro.Parent then flyBodyGyro:Destroy() end
    flyBodyVel  = nil
    flyBodyGyro = nil
    local char = LocalPlayer.Character
    if char then
        local hum = getHum(char)
        if hum then hum.PlatformStand = false end
    end
    pcall(function() workspace.CurrentCamera.CameraType = Enum.CameraType.Custom end)
end

local function disableAllFly()
    disableNormalFly()
    disableCFrameFly()
    FLYING        = false
    currentFlyType = "none"
end

-- Internal fly engine: vfly=false → Normal Fly, vfly=true → Vehicle Fly
local function enableNormalFlyInternal(vfly, speed)
    disableAllFly()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum  = getHum(char)
    if not hum then return end
    local T = getRoot(char)
    if not T then return end

    local CONTROL  = {F=0, B=0, L=0, R=0, UP=0, DN=0}
    local lCONTROL = {F=0, B=0, L=0, R=0, UP=0, DN=0}
    local SPEED    = 0
    local flyMult  = speed or iyflyspeed

    FLYING        = true
    currentFlyType = vfly and "vehicle" or "normal"

    local BG = Instance.new("BodyGyro")
    BG.P         = 9e4
    BG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    BG.CFrame    = T.CFrame
    BG.Parent    = T

    local BV = Instance.new("BodyVelocity")
    BV.Velocity  = Vector3.new(0, 0, 0)
    BV.MaxForce  = Vector3.new(9e9, 9e9, 9e9)
    BV.Parent    = T

    flyBodyGyro = BG
    flyBodyVel  = BV

    task.spawn(function()
        repeat
            task.wait()
            local camera = workspace.CurrentCamera
            if not vfly and hum then hum.PlatformStand = true end

            local anyMove = (CONTROL.L+CONTROL.R ~= 0) or (CONTROL.F+CONTROL.B ~= 0) or (CONTROL.UP+CONTROL.DN ~= 0)
            SPEED = anyMove and (50 * flyMult) or 0

            if anyMove then
                BV.Velocity = (
                    (camera.CFrame.LookVector * (CONTROL.F + CONTROL.B)) +
                    ((camera.CFrame * CFrame.new(CONTROL.L + CONTROL.R,
                        (CONTROL.F+CONTROL.B+CONTROL.UP+CONTROL.DN)*0.2, 0)).p
                    - camera.CFrame.p)
                ) * SPEED
                lCONTROL = {F=CONTROL.F, B=CONTROL.B, L=CONTROL.L, R=CONTROL.R, UP=CONTROL.UP, DN=CONTROL.DN}
            elseif SPEED ~= 0 then
                BV.Velocity = (
                    (camera.CFrame.LookVector * (lCONTROL.F + lCONTROL.B)) +
                    ((camera.CFrame * CFrame.new(lCONTROL.L+lCONTROL.R,
                        (lCONTROL.F+lCONTROL.B+CONTROL.UP+CONTROL.DN)*0.2, 0)).p
                    - camera.CFrame.p)
                ) * SPEED
            else
                BV.Velocity = Vector3.new(0, 0, 0)
            end
            BG.CFrame = camera.CFrame
        until not FLYING

        CONTROL  = {F=0, B=0, L=0, R=0, UP=0, DN=0}
        lCONTROL = {F=0, B=0, L=0, R=0, UP=0, DN=0}
        if BG.Parent then BG:Destroy() end
        if BV.Parent then BV:Destroy() end
        if hum then hum.PlatformStand = false end
    end)

    -- WASD + Space/Shift key bindings
    -- LeftShift: ignore processed because ShiftLock marks it as processed=true
    flyKeyDownConn = UserInputService.InputBegan:Connect(function(input, processed)
        local key = input.KeyCode
        if key == Enum.KeyCode.LeftShift then CONTROL.DN = -flyMult * 2; return end
        if processed then return end
        if     key == Enum.KeyCode.W     then CONTROL.F  =  flyMult
        elseif key == Enum.KeyCode.S     then CONTROL.B  = -flyMult
        elseif key == Enum.KeyCode.A     then CONTROL.L  = -flyMult
        elseif key == Enum.KeyCode.D     then CONTROL.R  =  flyMult
        elseif key == Enum.KeyCode.Space then CONTROL.UP =  flyMult * 2
        end
    end)

    flyKeyUpConn = UserInputService.InputEnded:Connect(function(input, processed)
        local key = input.KeyCode
        if key == Enum.KeyCode.LeftShift then CONTROL.DN = 0; return end
        if processed then return end
        if     key == Enum.KeyCode.W     then CONTROL.F  = 0
        elseif key == Enum.KeyCode.S     then CONTROL.B  = 0
        elseif key == Enum.KeyCode.A     then CONTROL.L  = 0
        elseif key == Enum.KeyCode.D     then CONTROL.R  = 0
        elseif key == Enum.KeyCode.Space then CONTROL.UP = 0
        end
    end)
end

-- CFrame Fly: anchors Head and moves via Heartbeat — faster, causes noclip effect
local function enableCFrameFly(speed)
    disableAllFly()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum  = getHum(char)
    if not hum then return end
    local head = char:WaitForChild("Head", 5)
    if not head then return end

    hum.PlatformStand = true
    head.Anchored     = true
    FLYING            = true
    currentFlyType    = "cframe"

    local cfSpd    = speed or CFspeed
    local cfUpDown = 0

    -- LeftShift: ignore processed because ShiftLock marks it as processed=true
    local cfKeyDown = UserInputService.InputBegan:Connect(function(input, processed)
        local key = input.KeyCode
        if key == Enum.KeyCode.LeftShift then
            cfUpDown = -1
        elseif not processed and key == Enum.KeyCode.Space then
            cfUpDown = 1
        end
    end)
    local cfKeyUp = UserInputService.InputEnded:Connect(function(input, processed)
        local key = input.KeyCode
        if key == Enum.KeyCode.LeftShift or (not processed and key == Enum.KeyCode.Space) then
            cfUpDown = 0
        end
    end)

    CFloop = RunService.Heartbeat:Connect(function(dt)
        if not (head and head.Parent) then
            cfKeyDown:Disconnect(); cfKeyUp:Disconnect(); return
        end
        local moveDir   = hum.MoveDirection * (cfSpd * dt)
        local headCF    = head.CFrame
        local camera    = workspace.CurrentCamera
        local camCF     = camera.CFrame
        local camOffset = headCF:ToObjectSpace(camCF).Position
        camCF = camCF * CFrame.new(-camOffset.X, -camOffset.Y, -camOffset.Z + 1)
        local camPos    = camCF.Position
        local headPos   = headCF.Position
        local objVel    = CFrame.new(camPos, Vector3.new(headPos.X, camPos.Y, headPos.Z)):VectorToObjectSpace(moveDir)
        local vertOffset = Vector3.new(0, cfUpDown * cfSpd * dt, 0)
        head.CFrame = CFrame.new(headPos + vertOffset) * (camCF - camPos) * CFrame.new(objVel)
    end)
end

-- Public fly interface
local function enableNormalFly(speed)  enableNormalFlyInternal(false, speed) end
local function enableVehicleFly(speed) enableNormalFlyInternal(true,  speed) end
local function enableCFly(speed)       enableCFrameFly(speed) end

-- ================================================================
--  WALK SPEED SYSTEM  (Normal / Loop)
-- ================================================================
local currentSpeedType = "normal"
local loopSpeedConn    = nil
local loopSpeedCA      = nil
local loopSpeedValue   = 50

local function applyNormalSpeed(value)
    local char = LocalPlayer.Character
    local hum  = char and getHum(char)
    if hum then hum.WalkSpeed = value or 50 end
end

local function disconnectLoopSpeed()
    if loopSpeedConn then loopSpeedConn:Disconnect(); loopSpeedConn = nil end
    if loopSpeedCA   then loopSpeedCA:Disconnect();   loopSpeedCA   = nil end
end

-- Loop mode: re-applies speed whenever the server tries to change it
local function enableLoopSpeed(value)
    disconnectLoopSpeed()
    loopSpeedValue   = value or 50
    currentSpeedType = "loop"
    local char = LocalPlayer.Character
    local hum  = char and getHum(char)
    local function applySpeed()
        if hum and hum.Parent then hum.WalkSpeed = loopSpeedValue end
    end
    local function connectHum(h)
        hum = h
        applySpeed()
        loopSpeedConn = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(applySpeed)
    end
    if hum then connectHum(hum) end
    loopSpeedCA = LocalPlayer.CharacterAdded:Connect(function(newChar)
        local newHum = newChar:WaitForChild("Humanoid", 10)
        if newHum and currentSpeedType == "loop" then connectHum(newHum) end
    end)
end

local function disableLoopSpeed()
    disconnectLoopSpeed()
    currentSpeedType = "normal"
end

local function disableAllSpeed()
    disableLoopSpeed()
    applyNormalSpeed(16)    -- Roblox default WalkSpeed
end

-- ================================================================
--  JUMP POWER SYSTEM  (Normal / Loop)
-- ================================================================
local currentJumpType = "normal"
local loopJumpConn    = nil
local loopJumpCA      = nil
local loopJumpValue   = 80

-- Supports both UseJumpPower=true (JumpPower) and UseJumpPower=false (JumpHeight)
local function applyNormalJump(value)
    local char = LocalPlayer.Character
    local hum  = char and getHum(char)
    if hum then
        if hum.UseJumpPower then
            hum.JumpPower  = value or 50
        else
            hum.JumpHeight = value or 7.2
        end
    end
end

local function disconnectLoopJump()
    if loopJumpConn then loopJumpConn:Disconnect(); loopJumpConn = nil end
    if loopJumpCA   then loopJumpCA:Disconnect();   loopJumpCA   = nil end
end

local function enableLoopJump(value)
    disconnectLoopJump()
    loopJumpValue   = value or 80
    currentJumpType = "loop"
    local char = LocalPlayer.Character
    local hum  = char and getHum(char)
    local function applyJump()
        if hum and hum.Parent then
            if hum.UseJumpPower then hum.JumpPower  = loopJumpValue
            else                     hum.JumpHeight = loopJumpValue end
        end
    end
    local function connectHum(h)
        hum = h
        applyJump()
        local propName = hum.UseJumpPower and "JumpPower" or "JumpHeight"
        loopJumpConn = hum:GetPropertyChangedSignal(propName):Connect(applyJump)
    end
    if hum then connectHum(hum) end
    loopJumpCA = LocalPlayer.CharacterAdded:Connect(function(newChar)
        local newHum = newChar:WaitForChild("Humanoid", 10)
        if newHum and currentJumpType == "loop" then connectHum(newHum) end
    end)
end

local function disableLoopJump()
    disconnectLoopJump()
    currentJumpType = "normal"
end

local function disableAllJump()
    disableLoopJump()
    applyNormalJump(50)
end

-- ================================================================
--  INFINITE JUMP SYSTEM  (Normal / Fly)
-- ================================================================
local currentInfJumpType = "none"
local infJumpConn        = nil

local function disconnectInfJump()
    if infJumpConn then infJumpConn:Disconnect(); infJumpConn = nil end
end

-- Normal mode: debounce prevents spam and avoids conflicts with fly
local function enableNormalInfJump()
    disconnectInfJump()
    currentInfJumpType = "normal"
    local debounce = false
    infJumpConn = UserInputService.JumpRequest:Connect(function()
        if debounce then return end
        debounce = true
        local char = LocalPlayer.Character
        local hum  = char and getHum(char)
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
        task.wait(0.05)
        debounce = false
    end)
end

-- Fly mode: no debounce — more responsive when used alongside fly
local function enableFlyInfJump()
    disconnectInfJump()
    currentInfJumpType = "fly"
    infJumpConn = UserInputService.JumpRequest:Connect(function()
        local char = LocalPlayer.Character
        local hum  = char and getHum(char)
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end)
end

local function disableInfJump()
    disconnectInfJump()
    currentInfJumpType = "none"
end

-- Legacy flyjump (kept for compatibility with Page1 button)
local flyjumpConn = nil
local function flyjumpDisconnect()
    if flyjumpConn then flyjumpConn:Disconnect(); flyjumpConn = nil end
end
local function enableFlyjump()
    flyjumpDisconnect()
    flyjumpConn = UserInputService.JumpRequest:Connect(function()
        local char = LocalPlayer.Character
        local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end)
end
local function disableFlyjump()
    flyjumpDisconnect()
end

-- ================================================================
--  NOCLIP SYSTEM
-- ================================================================
local Clip           = true
local Noclipping     = nil
local noclippedParts = {}

local function NoclippingDisconnect()
    if Noclipping then Noclipping:Disconnect(); Noclipping = nil end
end

local function enableNoclip()
    NoclippingDisconnect()
    Clip = false
    noclippedParts = {}
    Noclipping = RunService.Stepped:Connect(function()
        if Clip == false and LocalPlayer.Character ~= nil then
            for _, child in pairs(LocalPlayer.Character:GetDescendants()) do
                if child:IsA("BasePart") and child.CanCollide == true then
                    child.CanCollide = false
                    noclippedParts[child] = true
                end
            end
        end
    end)
end

local function disableNoclip()
    Clip = true
    NoclippingDisconnect()
    for part in pairs(noclippedParts) do
        if part and part.Parent then part.CanCollide = true end
    end
    noclippedParts = {}
end

-- ================================================================
--  ANTI-KILL BRICKS SYSTEM v6.0
--  Protection: CanTouch disabling + Health hook + Player filtering
-- ================================================================
local AK_CONFIG = {
    radius       = 26,
    throttleRate = 0.1,
}

local akState = {
    enabled     = false,
    touched     = {},
    connections = {},
    charConn    = nil,
    lastCheck   = 0,
}

local akOverlapParams = OverlapParams.new()
akOverlapParams.FilterType = Enum.RaycastFilterType.Exclude

local function akIsPlayerPart(part)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and part:IsDescendantOf(plr.Character) then
            return true
        end
    end
    return false
end

local function akRestoreTouched()
    for part in pairs(akState.touched) do
        if part and part.Parent then pcall(function() part.CanTouch = true end) end
    end
    akState.touched = {}
end

local function akDisconnectAll()
    for _, conn in ipairs(akState.connections) do pcall(function() conn:Disconnect() end) end
    akState.connections = {}
end

local function akOnStepped(_, dt)
    if not akState.enabled then return end
    akState.lastCheck = akState.lastCheck + dt
    if akState.lastCheck < AK_CONFIG.throttleRate then return end
    akState.lastCheck = 0
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local filterList = {char}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            filterList[#filterList+1] = plr.Character
        end
    end
    akOverlapParams.FilterDescendantsInstances = filterList
    local nearby = workspace:GetPartBoundsInRadius(root.Position, AK_CONFIG.radius, akOverlapParams)
    for _, part in ipairs(nearby) do
        if part.CanTouch and not part:IsDescendantOf(char) and not akIsPlayerPart(part) then
            part.CanTouch = false
            akState.touched[part] = true
        end
    end
end

local function akOnHeartbeat()
    if not akState.enabled then return end
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    if humanoid.Health > 0 and humanoid.Health < humanoid.MaxHealth then
        humanoid.Health        = humanoid.MaxHealth
        humanoid.PlatformStand = false
    end
end

local function akSetupCharacter()
    task.wait(0.7)
    akRestoreTouched()
    akState.lastCheck = 0
    if akState.enabled then
        print("Anti-Kill v6.0: Respawn detected — protection resumed")
    end
end

local function enableAntiKill()
    if akState.enabled then return end
    akState.enabled   = true
    akState.touched   = {}
    akState.lastCheck = 0
    if not akState.charConn then
        akState.charConn = LocalPlayer.CharacterAdded:Connect(akSetupCharacter)
    end
    table.insert(akState.connections, RunService.Stepped:Connect(akOnStepped))
    table.insert(akState.connections, RunService.Heartbeat:Connect(akOnHeartbeat))
end

local function disableAntiKill()
    if not akState.enabled then return end
    akState.enabled = false
    akDisconnectAll()
    akRestoreTouched()
end

-- ================================================================
--  TELEPORT TOOL
-- ================================================================
local activeTpTool     = nil
local tpToolEnabled    = false
local isSpawningTpTool = false

local function spawnTpToolInBackpack(backpack)
    if isSpawningTpTool then return end
    isSpawningTpTool = true
    for _, item in pairs(backpack:GetChildren()) do
        if item.Name == "Teleport Tool" then item:Destroy() end
    end
    local char = LocalPlayer.Character
    if char then
        for _, item in pairs(char:GetChildren()) do
            if item.Name == "Teleport Tool" then item:Destroy() end
        end
    end
    activeTpTool = nil
    local TpTool = Instance.new("Tool")
    TpTool.Name           = "Teleport Tool"
    TpTool.RequiresHandle = false
    TpTool.Parent         = backpack
    TpTool.Activated:Connect(function()
        local root = getRoot(LocalPlayer.Character)
        local pos  = IYMouse.Hit
        if not root or not pos then return end
        root.CFrame = CFrame.new(pos.X, pos.Y + 3, pos.Z, select(4, root.CFrame:components()))
        pcall(breakVelocity)
    end)
    activeTpTool     = TpTool
    isSpawningTpTool = false
end

local function enableTeleportTool()
    tpToolEnabled = true
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    if backpack then spawnTpToolInBackpack(backpack) end
end

local function disableTeleportTool()
    tpToolEnabled = false
    if activeTpTool and activeTpTool.Parent then activeTpTool:Destroy() end
    activeTpTool = nil
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item.Name == "Teleport Tool" then item:Destroy() end
        end
    end
    local char = LocalPlayer.Character
    if char then
        for _, item in pairs(char:GetChildren()) do
            if item.Name == "Teleport Tool" then item:Destroy() end
        end
    end
end

-- ================================================================
--  CLICK TELEPORT  (Left Alt + Left Click)
-- ================================================================
local clickTpConn = nil

local function clicktpFunc()
    pcall(function()
        local character = LocalPlayer.Character
        if not character then return end
        local humanoid  = character:FindFirstChildOfClass("Humanoid")
        if humanoid and humanoid.SeatPart then
            humanoid.Sit = false
            task.wait(0.1)
        end
        local hipHeight   = humanoid and humanoid.HipHeight > 0 and (humanoid.HipHeight + 1)
        local rootPart    = getRoot(character)
        local rootPartPos = rootPart.Position
        local hitPosition = IYMouse.Hit.Position
        local newCFrame   = CFrame.new(hitPosition,
            Vector3.new(rootPartPos.X, hitPosition.Y, rootPartPos.Z)
        ) * CFrame.Angles(0, math.pi, 0)
        rootPart.CFrame = newCFrame + Vector3.new(0, hipHeight or 4, 0)
        pcall(breakVelocity)
    end)
end

local function enableClickTp()
    if clickTpConn then clickTpConn:Disconnect(); clickTpConn = nil end
    clickTpConn = IYMouse.Button1Down:Connect(function()
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftAlt) then
            clicktpFunc()
        end
    end)
end

local function disableClickTp()
    if clickTpConn then clickTpConn:Disconnect(); clickTpConn = nil end
end

-- ================================================================
--  PLAYER ESP SYSTEM
-- ================================================================
local espEnabled    = false
local espBillboards = {}
local espLoop       = nil
local espNameMode   = "username"    -- "username" | "displayname" | "displayonly"

local function formatDist(d)
    return d >= 1000 and string.format("%.1fk", d/1000) or string.format("%d", math.floor(d))
end

local function createESPLabel(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end
    if espBillboards[player] then espBillboards[player]:Destroy(); espBillboards[player] = nil end

    local bb = Instance.new("BillboardGui")
    bb.Name         = "ClatyESP"
    bb.Adornee      = head
    bb.AlwaysOnTop  = true
    bb.Size         = UDim2.new(0, 100, 0, 52)
    bb.StudsOffset  = Vector3.new(0, 2.4, 0)
    bb.ResetOnSpawn = false
    bb.Parent       = head

    local function makeLabel(text, color, yPos, textSize)
        local lbl = Instance.new("TextLabel")
        lbl.Size                   = UDim2.new(1, 0, 0, textSize + 2)
        lbl.Position               = UDim2.new(0, 0, 0, yPos)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3             = color
        lbl.Font                   = Enum.Font.GothamBold
        lbl.TextSize               = textSize
        lbl.TextStrokeTransparency = 0.4
        lbl.TextStrokeColor3       = Color3.new(0, 0, 0)
        lbl.Text                   = text
        lbl.Parent                 = bb
        return lbl
    end

    local nameL = makeLabel(player.Name,  Color3.new(1,1,1),              0,  13)
    local hpL   = makeLabel("HP: 100",    Color3.fromRGB(255, 80,  80),  15,  12)
    local distL = makeLabel("0m",         Color3.fromRGB(80,  220, 100), 27,  12)

    espBillboards[player] = bb

    local function refreshNameLabel()
        if espNameMode == "username" then
            nameL.Text = player.Name
        elseif espNameMode == "displayname" then
            nameL.Text = (player.DisplayName ~= player.Name)
                and (player.Name .. " (" .. player.DisplayName .. ")")
                or player.Name
        elseif espNameMode == "displayonly" then
            nameL.Text = player.DisplayName
        else
            nameL.Text = player.Name
        end
    end

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not espEnabled or not bb or not bb.Parent then conn:Disconnect(); return end
        refreshNameLabel()
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        hpL.Text = hum and ("HP: " .. math.floor(hum.Health)) or "HP: ?"
        local myRoot  = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local itsRoot = char and char:FindFirstChild("HumanoidRootPart")
        if myRoot and itsRoot then
            distL.Text = formatDist((myRoot.Position - itsRoot.Position).Magnitude)
        end
    end)
end

local function removeESPLabel(player)
    if espBillboards[player] then espBillboards[player]:Destroy(); espBillboards[player] = nil end
end

local function enablePlayerESP()
    espEnabled = true
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then createESPLabel(player) end
    end
    espLoop = Players.PlayerAdded:Connect(function(player)
        player.CharacterAdded:Connect(function()
            task.wait(0.5)
            if espEnabled then createESPLabel(player) end
        end)
    end)
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            player.CharacterAdded:Connect(function()
                task.wait(0.5)
                if espEnabled then createESPLabel(player) end
            end)
        end
    end
end

local function disablePlayerESP()
    espEnabled = false
    if espLoop then espLoop:Disconnect(); espLoop = nil end
    for player in pairs(espBillboards) do removeESPLabel(player) end
    for _, player in pairs(Players:GetPlayers()) do
        local char = player.Character
        if char then
            local head = char:FindFirstChild("Head")
            if head then
                local bb = head:FindFirstChild("ClatyESP")
                if bb then bb:Destroy() end
            end
        end
    end
end

-- ================================================================
--  FE INVISIBILITY ENGINE v2.4
--  Method: Seat + Transparency + CharacterAdded handler
-- ================================================================

-- Declared early so engine functions can reference it at runtime
local invisBoxes = {}

local invisEnabled      = false
local invisCurrentSeat  = nil
local invisTransparency = 0.75

-- Reads XYZ from invisBoxes inputs (defined later in GUI)
local function getInvisPosition()
    local x = invisBoxes and tonumber(invisBoxes["X"] and invisBoxes["X"].Text) or 0
    local y = invisBoxes and tonumber(invisBoxes["Y"] and invisBoxes["Y"].Text) or 400
    local z = invisBoxes and tonumber(invisBoxes["Z"] and invisBoxes["Z"].Text) or 0
    local voidY = workspace.FallenPartsDestroyHeight
    if y < voidY + 10 then y = voidY + 50 end
    return Vector3.new(x, y, z)
end

local function invisSetTransparency(transparency)
    local character = LocalPlayer.Character
    if not character then return end
    for _, obj in pairs(character:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
            obj.Transparency = transparency
            if obj:FindFirstChild("Mesh") then
                obj.Mesh.VertexColor = Vector3.new(1, 1, 1)
            end
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj.Transparency = transparency
        end
    end
end

local function invisCreateSeat(savedCFrame, targetPos)
    if invisCurrentSeat then invisCurrentSeat:Destroy() end
    local seat = Instance.new("Seat")
    seat.Name         = "ClatyInvisSeat"
    seat.Anchored     = false
    seat.CanCollide   = false
    seat.CanTouch     = false
    seat.Transparency = 1
    seat.Position     = targetPos
    seat.Parent       = workspace
    local torso = LocalPlayer.Character:FindFirstChild("UpperTorso")
                  or LocalPlayer.Character:FindFirstChild("Torso")
    if torso then
        local weld  = Instance.new("Weld")
        weld.Part0  = seat
        weld.Part1  = torso
        weld.Parent = seat
    end
    task.wait(0.05)
    seat.CFrame      = savedCFrame
    invisCurrentSeat = seat
end

local function enableInvis()
    if invisEnabled then return end
    invisEnabled = true
    local character = LocalPlayer.Character
    if not character then invisEnabled = false; return end
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root then invisEnabled = false; return end
    local savedCFrame = root.CFrame
    local targetPos   = getInvisPosition()
    invisSetTransparency(invisTransparency)
    task.wait(0.08)
    root.CFrame = CFrame.new(targetPos)
    task.wait(0.08)
    invisCreateSeat(savedCFrame, targetPos)
end

local function disableInvis()
    if not invisEnabled then return end
    invisEnabled = false
    invisSetTransparency(0)
    if invisCurrentSeat then
        invisCurrentSeat:Destroy()
        invisCurrentSeat = nil
    end
end

