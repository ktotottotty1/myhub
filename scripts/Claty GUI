local savedCount = 0
local MAX_SAVED  = 10
local totalAdded = 0

local function addSavedSlot(px, py, pz)
    if savedCount >= MAX_SAVED then return end
    savedCount = savedCount + 1
    totalAdded = totalAdded + 1
    local slotNum = totalAdded

    local slot = Instance.new("Frame")
    slot.Size             = UDim2.new(1, 0, 0, 114)
    slot.BackgroundColor3 = C.Section
    slot.BorderSizePixel  = 0
    slot.Parent           = SideList
    addCorner(slot, CORNER_S)
    addStroke(slot, C.Stroke, 1)

    -- Slot name box
    local nameWrap = Instance.new("Frame")
    nameWrap.Size             = UDim2.new(1, -36, 0, 22)
    nameWrap.Position         = UDim2.new(0, 6, 0, 6)
    nameWrap.BackgroundColor3 = C.Input
    nameWrap.BorderSizePixel  = 0
    nameWrap.Parent           = slot
    addCorner(nameWrap, UDim.new(0, 5))
    addStroke(nameWrap, C.Stroke, 1)

    local nameBox = Instance.new("TextBox")
    nameBox.Size             = UDim2.new(1, -10, 1, 0)
    nameBox.Position         = UDim2.new(0, 5, 0, 0)
    nameBox.BackgroundTransparency = 1
    nameBox.TextColor3       = C.Text
    nameBox.Font             = Enum.Font.GothamBold
    nameBox.TextSize         = 11
    nameBox.Text             = "Slot " .. slotNum
    nameBox.ClearTextOnFocus = false
    nameBox.PlaceholderText  = "Name..."
    nameBox.PlaceholderColor3 = C.SubText
    nameBox.TextXAlignment   = Enum.TextXAlignment.Left
    nameBox.Parent           = nameWrap

    -- Delete button
    local delBtn = Instance.new("TextButton")
    delBtn.Size             = UDim2.new(0, 22, 0, 22)
    delBtn.Position         = UDim2.new(1, -28, 0, 6)
    delBtn.BackgroundColor3 = Color3.fromRGB(160, 40, 40)
    delBtn.Text             = "×"
    delBtn.TextColor3       = Color3.new(1, 1, 1)
    delBtn.Font             = Enum.Font.GothamBold
    delBtn.TextSize         = 13
    delBtn.BorderSizePixel  = 0
    delBtn.Parent           = slot
    addCorner(delBtn, UDim.new(0, 5))
    addStroke(delBtn, Color3.fromRGB(120, 30, 30), 1)
    delBtn.MouseButton1Click:Connect(function()
        slot:Destroy()
        savedCount = savedCount - 1
    end)

    -- XYZ coordinate inputs
    local slotXYZRow = Instance.new("Frame")
    slotXYZRow.Size             = UDim2.new(1, -12, 0, 32)
    slotXYZRow.Position         = UDim2.new(0, 6, 0, 34)
    slotXYZRow.BackgroundTransparency = 1
    slotXYZRow.Parent           = slot
    addListLayout(slotXYZRow, Enum.FillDirection.Horizontal, 4)

    local slotBoxes = {}
    for i, axis in ipairs({"X", "Y", "Z"}) do
        local wrap2 = Instance.new("Frame")
        wrap2.Size             = UDim2.new(0.333, -3, 1, 0)
        wrap2.BackgroundColor3 = C.Input
        wrap2.BorderSizePixel  = 0
        wrap2.LayoutOrder      = i
        wrap2.Parent           = slotXYZRow
        addCorner(wrap2, UDim.new(0, 6))
        addStroke(wrap2, C.Stroke, 1)

        local axl = Instance.new("TextLabel")
        axl.Size             = UDim2.new(0, 16, 1, 0)
        axl.Position         = UDim2.new(0, 5, 0, 0)
        axl.BackgroundTransparency = 1
        axl.TextColor3       = C.SubText
        axl.Font             = Enum.Font.GothamBold
        axl.TextSize         = 10
        axl.Text             = axis
        axl.Parent           = wrap2

        local box2 = Instance.new("TextBox")
        box2.Size             = UDim2.new(1, -22, 1, 0)
        box2.Position         = UDim2.new(0, 20, 0, 0)
        box2.BackgroundTransparency = 1
        box2.TextColor3       = C.Text
        box2.Font             = Enum.Font.GothamBold
        box2.TextSize         = 11
        box2.ClearTextOnFocus = false
        box2.PlaceholderText  = "0"
        box2.PlaceholderColor3 = C.SubText
        box2.TextXAlignment   = Enum.TextXAlignment.Center
        box2.Parent           = wrap2
        slotBoxes[axis] = box2
    end

    slotBoxes["X"].Text = px and tostring(px) or ""
    slotBoxes["Y"].Text = py and tostring(py) or ""
    slotBoxes["Z"].Text = pz and tostring(pz) or ""

    -- Action buttons: Set / Copy / Write / TP
    local btnRow2 = Instance.new("Frame")
    btnRow2.Size             = UDim2.new(1, -12, 0, 26)
    btnRow2.Position         = UDim2.new(0, 6, 0, 74)
    btnRow2.BackgroundTransparency = 1
    btnRow2.Parent           = slot
    addListLayout(btnRow2, Enum.FillDirection.Horizontal, 4)

    local function makeSlotBtn(label, order, col, onClick2)
        local b = Instance.new("TextButton")
        b.Size             = UDim2.new(0.25, -3, 1, 0)
        b.BackgroundColor3 = col or C.Row
        b.Text             = label
        b.TextColor3       = Color3.new(1, 1, 1)
        b.Font             = Enum.Font.GothamBold
        b.TextSize         = 11
        b.BorderSizePixel  = 0
        b.LayoutOrder      = order
        b.Parent           = btnRow2
        addCorner(b, UDim.new(0, 6))
        addStroke(b, C.Stroke, 1)
        local origCol = col or C.Row
        b.MouseButton1Click:Connect(function()
            task.spawn(onClick2)
            b.BackgroundColor3 = Color3.fromRGB(26, 78, 46)
            task.delay(0.22, function() b.BackgroundColor3 = origCol end)
        end)
    end

    makeSlotBtn("Set", 1, Color3.fromRGB(0,110,210), function()
        local r = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not r then return end
        local p = r.Position
        slotBoxes["X"].Text = tostring(math.floor(p.X*10+0.5)/10)
        slotBoxes["Y"].Text = tostring(math.floor(p.Y*10+0.5)/10)
        slotBoxes["Z"].Text = tostring(math.floor(p.Z*10+0.5)/10)
    end)
    makeSlotBtn("Copy", 2, Color3.fromRGB(36,130,70), function()
        local x, y, z = slotBoxes["X"].Text, slotBoxes["Y"].Text, slotBoxes["Z"].Text
        pcall(setclipboard, string.format("%s, %s, %s", x, y, z))
        _copiedCoords = {X=tonumber(x) or 0, Y=tonumber(y) or 0, Z=tonumber(z) or 0}
    end)
    makeSlotBtn("Write", 3, Color3.fromRGB(55,55,75), function()
        if not _copiedCoords then return end
        task.defer(function()
            slotBoxes["X"].Text = tostring(_copiedCoords.X)
            slotBoxes["Y"].Text = tostring(_copiedCoords.Y)
            slotBoxes["Z"].Text = tostring(_copiedCoords.Z)
        end)
    end)
    makeSlotBtn("TP", 4, Color3.fromRGB(180,100,20), function()
        local r = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not r then return end
        r.CFrame = CFrame.new(
            tonumber(slotBoxes["X"].Text) or r.Position.X,
            tonumber(slotBoxes["Y"].Text) or r.Position.Y,
            tonumber(slotBoxes["Z"].Text) or r.Position.Z
        )
    end)
end

AddBtn.MouseButton1Click:Connect(function()
    if savedCount >= MAX_SAVED then return end
    addSavedSlot(nil, nil, nil)
    TweenService:Create(AddBtn, TweenInfo.new(0.08), {BackgroundColor3=Color3.fromRGB(20,120,50)}):Play()
    task.delay(0.18, function()
        TweenService:Create(AddBtn, TweenInfo.new(0.12), {BackgroundColor3=Color3.fromRGB(40,165,80)}):Play()
    end)
end)

local sidePanelOpen = false
closeSidePanel = function()
    sidePanelOpen     = false
    SidePanel.Visible = false
    TweenService:Create(SaveBtn, TweenInfo.new(0.08), {BackgroundColor3=Color3.fromRGB(38,38,52)}):Play()
end
SideCloseBtn.MouseButton1Click:Connect(closeSidePanel)
SaveBtn.MouseButton1Click:Connect(function()
    sidePanelOpen = not sidePanelOpen
    repositionSidePanel()
    SidePanel.Visible = sidePanelOpen
    TweenService:Create(SaveBtn, TweenInfo.new(0.08), {
        BackgroundColor3 = sidePanelOpen and Color3.fromRGB(28,28,52) or Color3.fromRGB(38,38,52)
    }):Play()
end)

-- ================================================================
--  PAGE 1 — ROW COMPONENT FACTORY
-- ================================================================

local function makeRow(parent, labelText, layout, order, defaultVal, featureKey, onToggle)
    local ROW_H = 37

    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, 0, 0, ROW_H)
    row.BackgroundTransparency = 1
    row.LayoutOrder      = order
    row.Parent           = parent

    -- Shared pill indicator (ON/OFF label inside a rounded badge)
    local function makePill(parent2)
        local pill = Instance.new("Frame")
        pill.Size             = UDim2.new(0, 54, 0, 22)
        pill.Position         = UDim2.new(1, -62, 0.5, -11)
        pill.BackgroundColor3 = Color3.fromRGB(28, 28, 38)
        pill.BorderSizePixel  = 0
        pill.Parent           = parent2
        addCorner(pill, UDim.new(0, 6))

        local pillLbl = Instance.new("TextLabel")
        pillLbl.Size             = UDim2.new(1, 0, 1, 0)
        pillLbl.BackgroundTransparency = 1
        pillLbl.TextColor3       = C.SubText
        pillLbl.Font             = Enum.Font.GothamBold
        pillLbl.TextSize         = 12
        pillLbl.Text             = "OFF"
        pillLbl.Parent           = pill
        return pill, pillLbl
    end

    if layout == "toggle_only" then
        -- Toggle row with no input box
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(1, 0, 1, 0)
        btn.BackgroundColor3 = C.Row
        btn.Text             = ""
        btn.BorderSizePixel  = 0
        btn.Parent           = row
        addCorner(btn, CORNER_S)
        addStroke(btn, C.Stroke, 1)

        local lbl = Instance.new("TextLabel")
        lbl.Size             = UDim2.new(1, -80, 1, 0)
        lbl.Position         = UDim2.new(0, 16, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3       = C.Text
        lbl.Font             = Enum.Font.GothamBold
        lbl.TextSize         = 13
        lbl.Text             = labelText
        lbl.TextXAlignment   = Enum.TextXAlignment.Left
        lbl.Parent           = btn

        local pill, pillLbl = makePill(btn)
        local isOn = false

        -- Click Teleport shows a hint about the shortcut
        if featureKey == "clicktp" then
            local hintLbl = Instance.new("TextLabel")
            hintLbl.Size             = UDim2.new(1, -80, 0, 12)
            hintLbl.Position         = UDim2.new(0, 16, 1, -13)
            hintLbl.BackgroundTransparency = 1
            hintLbl.TextColor3       = C.SubText
            hintLbl.Font             = Enum.Font.Gotham
            hintLbl.TextSize         = 9
            hintLbl.Text             = "Left Alt + Left Click"
            hintLbl.TextXAlignment   = Enum.TextXAlignment.Left
            hintLbl.Parent           = btn
        end

        btn.MouseButton1Click:Connect(function()
            isOn = not isOn
            TweenService:Create(btn, TweenInfo.new(0.13), {
                BackgroundColor3 = isOn and Color3.fromRGB(26,78,46) or C.Row
            }):Play()
            TweenService:Create(pill, TweenInfo.new(0.13), {
                BackgroundColor3 = isOn and C.BtnOn or Color3.fromRGB(28,28,38)
            }):Play()
            pillLbl.Text       = isOn and "ON" or "OFF"
            pillLbl.TextColor3 = isOn and Color3.new(1,1,1) or C.SubText
            if onToggle then onToggle(isOn) end
        end)

        if featureKey then
            featureStates[featureKey] = {
                isOn  = function() return isOn end,
                setOff = function()
                    if isOn then
                        isOn = false
                        pcall(function()
                            TweenService:Create(btn,  TweenInfo.new(0.13), {BackgroundColor3=C.Row}):Play()
                            TweenService:Create(pill, TweenInfo.new(0.13), {BackgroundColor3=Color3.fromRGB(28,28,38)}):Play()
                            pillLbl.Text       = "OFF"
                            pillLbl.TextColor3 = C.SubText
                        end)
                    end
                end,
            }
        end

    elseif layout == "disabled" then
        -- Coming Soon: greyed out, non-interactive
        local GRAY = Color3.fromRGB(38, 38, 50)
        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(1, 0, 1, 0)
        btn.BackgroundColor3 = GRAY
        btn.Text             = ""
        btn.BorderSizePixel  = 0
        btn.AutoButtonColor  = false
        btn.Active           = false
        btn.Parent           = row
        addCorner(btn, CORNER_S)
        addStroke(btn, Color3.fromRGB(45, 45, 58), 1)

        local lbl = Instance.new("TextLabel")
        lbl.Size             = UDim2.new(1, -100, 1, 0)
        lbl.Position         = UDim2.new(0, 16, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3       = Color3.fromRGB(70, 70, 88)
        lbl.Font             = Enum.Font.GothamBold
        lbl.TextSize         = 13
        lbl.Text             = labelText
        lbl.TextXAlignment   = Enum.TextXAlignment.Left
        lbl.Parent           = btn

        local csLbl = Instance.new("TextLabel")
        csLbl.Size             = UDim2.new(0, 90, 1, 0)
        csLbl.Position         = UDim2.new(1, -96, 0, 0)
        csLbl.BackgroundTransparency = 1
        csLbl.TextColor3       = Color3.fromRGB(60, 60, 78)
        csLbl.Font             = Enum.Font.GothamBold
        csLbl.TextSize         = 10
        csLbl.Text             = "Coming Soon"
        csLbl.TextXAlignment   = Enum.TextXAlignment.Center
        csLbl.Parent           = btn

    elseif layout == "toggle_box" then
        -- Toggle + numeric input box side by side
        local BTN_FRAC = 0.64
        local GAP      = 6

        local btn = Instance.new("TextButton")
        btn.Size             = UDim2.new(BTN_FRAC, -GAP/2, 1, 0)
        btn.BackgroundColor3 = C.Row
        btn.Text             = ""
        btn.BorderSizePixel  = 0
        btn.Parent           = row
        addCorner(btn, CORNER_S)
        addStroke(btn, C.Stroke, 1)

        local lbl = Instance.new("TextLabel")
        lbl.Size             = UDim2.new(1, -80, 1, 0)
        lbl.Position         = UDim2.new(0, 16, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextColor3       = C.Text
        lbl.Font             = Enum.Font.GothamBold
        lbl.TextSize         = 13
        lbl.Text             = labelText
        lbl.TextXAlignment   = Enum.TextXAlignment.Left
        lbl.Parent           = btn

        local pill, pillLbl = makePill(btn)

        local boxFrame = Instance.new("Frame")
        boxFrame.Size             = UDim2.new(1-BTN_FRAC, -GAP/2, 1, 0)
        boxFrame.Position         = UDim2.new(BTN_FRAC, GAP/2, 0, 0)
        boxFrame.BackgroundColor3 = C.Input
        boxFrame.BorderSizePixel  = 0
        boxFrame.Parent           = row
        addCorner(boxFrame, CORNER_S)
        addStroke(boxFrame, C.Stroke, 1)

        local box = Instance.new("TextBox")
        box.Size             = UDim2.new(1, -8, 0, 20)
        box.Position         = UDim2.new(0, 4, 0.5, -10)
        box.BackgroundTransparency = 1
        box.TextColor3       = C.Text
        box.Font             = Enum.Font.GothamBold
        box.TextSize         = 15
        box.Text             = tostring(defaultVal or "50")
        box.ClearTextOnFocus = false
        box.PlaceholderText  = "0"
        box.PlaceholderColor3 = C.SubText
        box.TextXAlignment   = Enum.TextXAlignment.Center
        box.Parent           = boxFrame

        local isOn = false

        btn.MouseButton1Click:Connect(function()
            isOn = not isOn
            TweenService:Create(btn, TweenInfo.new(0.13), {
                BackgroundColor3 = isOn and Color3.fromRGB(26,78,46) or C.Row
            }):Play()
            TweenService:Create(pill, TweenInfo.new(0.13), {
                BackgroundColor3 = isOn and C.BtnOn or Color3.fromRGB(28,28,38)
            }):Play()
            pillLbl.Text       = isOn and "ON" or "OFF"
            pillLbl.TextColor3 = isOn and Color3.new(1,1,1) or C.SubText
            if onToggle then onToggle(isOn, box) end
        end)

        -- Live-update the feature when the value box loses focus
        box.FocusLost:Connect(function()
            if not isOn then return end
            local v = tonumber(box.Text)
            if not v then return end
            if featureKey == "fly" then
                flySpeedValue = v
                if     settingsFlyType == "normal"  then enableNormalFly(v / 50)
                elseif settingsFlyType == "cframe"  then enableCFly(v)
                elseif settingsFlyType == "vehicle" then enableVehicleFly(v / 50)
                end
            elseif featureKey == "walkspeed" then
                walkSpeedValue = v
                if     settingsWalkSpeed == "normal" then applyNormalSpeed(v)
                elseif settingsWalkSpeed == "loop"   then loopSpeedValue = v
                end
            elseif featureKey == "jumppower" then
                jumpPowerValue = v
                if     settingsJumpPower == "normal" then applyNormalJump(v)
                elseif settingsJumpPower == "loop"   then loopJumpValue = v
                end
            end
        end)

        if featureKey then
            featureStates[featureKey] = {
                isOn   = function() return isOn end,
                getBox = function() return box end,
                setOff = function()
                    if isOn then
                        isOn = false
                        pcall(function()
                            TweenService:Create(btn,  TweenInfo.new(0.13), {BackgroundColor3=C.Row}):Play()
                            TweenService:Create(pill, TweenInfo.new(0.13), {BackgroundColor3=Color3.fromRGB(28,28,38)}):Play()
                            pillLbl.Text       = "OFF"
                            pillLbl.TextColor3 = C.SubText
                        end)
                    end
                end,
            }
        end
    end

    return row
end

-- ================================================================
--  PAGE 1 — FEATURE ROWS
