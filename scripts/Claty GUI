    -- Helper: radio button group with tween animation
    local function bindRadio(buttons, onChange)
        for _, item in ipairs(buttons) do
            item.btn.MouseButton1Click:Connect(function()
                for _, other in ipairs(buttons) do
                    local active = (other == item)
                    TweenService:Create(other.btn, TweenInfo.new(0.13), {
                        BackgroundColor3 = active and C.BtnOn or C.BtnOff
                    }):Play()
                    other.btn.TextColor3 = active and Color3.new(1,1,1) or C.SubText
                end
                if onChange then onChange(item.value) end
            end)
        end
    end

    -- ── 1. FLY TYPE ─────────────────────────────────────────────────
    local _, flyRow = makeSPSection("Fly Type", 1)
    local flyNormal  = makeSPBtn(flyRow, "Normal",  1, true,  0.33)
    local flyCFrame  = makeSPBtn(flyRow, "CFrame",  2, false, 0.33)
    local flyVehicle = makeSPBtn(flyRow, "Vehicle", 3, false, 0.33)

    bindRadio({
        {btn=flyNormal,  value="normal"},
        {btn=flyCFrame,  value="cframe"},
        {btn=flyVehicle, value="vehicle"},
    }, function(v)
        settingsFlyType = v
        if flyIsActive then
            disableAllFly()
            task.wait()
            if     v == "normal"  then enableNormalFly(flySpeedValue / 50)
            elseif v == "cframe"  then enableCFly(flySpeedValue)
            elseif v == "vehicle" then enableVehicleFly(flySpeedValue / 50)
            end
        end
    end)

    -- ── 2. WALK SPEED ────────────────────────────────────────────────
    local _, wsRow = makeSPSection("Walk Speed", 2)
    local wsNormal  = makeSPBtn(wsRow, "Normal", 1, true,  0.33)
    local _wsSoon   = makeSPSoonBtn(wsRow,       2,        0.33)
    local wsLoop    = makeSPBtn(wsRow, "Loop",   3, false, 0.33)

    bindRadio({
        {btn=wsNormal, value="normal"},
        {btn=wsLoop,   value="loop"},
    }, function(v)
        local prev = settingsWalkSpeed
        settingsWalkSpeed = v
        if speedIsActive then
            if prev == "loop" then disableLoopSpeed() end
            if     v == "normal" then applyNormalSpeed(walkSpeedValue)
            elseif v == "loop"   then enableLoopSpeed(walkSpeedValue)
            end
        end
    end)

    -- ── 3. JUMP POWER ────────────────────────────────────────────────
    local _, jpRow = makeSPSection("Jump Power", 3)
    local jpNormal  = makeSPBtn(jpRow, "Normal", 1, true,  0.33)
    local _jpSoon   = makeSPSoonBtn(jpRow,       2,        0.33)
    local jpLoop    = makeSPBtn(jpRow, "Loop",   3, false, 0.33)

    bindRadio({
        {btn=jpNormal, value="normal"},
        {btn=jpLoop,   value="loop"},
    }, function(v)
        local prev = settingsJumpPower
        settingsJumpPower = v
        if jumpIsActive then
            if prev == "loop" then disableLoopJump() end
            if     v == "normal" then applyNormalJump(jumpPowerValue)
            elseif v == "loop"   then enableLoopJump(jumpPowerValue)
            end
        end
    end)

    -- ── 4. INFINITE JUMP ─────────────────────────────────────────────
    local _, ijRow = makeSPSection("Infinite Jump", 4)
    local ijNormal  = makeSPBtn(ijRow, "Normal Inf Jump", 1, true,  0.5)
    local ijFly     = makeSPBtn(ijRow, "Fly Inf Jump",    2, false, 0.5)

    bindRadio({
        {btn=ijNormal, value="normal"},
        {btn=ijFly,    value="fly"},
    }, function(v)
        settingsInfJump = v
        if infJumpIsActive then
            disableInfJump()
            if     v == "normal" then enableNormalInfJump()
            elseif v == "fly"    then enableFlyInfJump()
            end
        end
    end)

    -- ── 5. PLAYER ESP NAME ───────────────────────────────────────────
    -- Two independent toggles (Username + Display Name) — not a radio group
    -- Rule: at least one must always remain active
    local _, espNameRow = makeSPSection("Player ESP Name", 5)

    local espUsreBtn = Instance.new("TextButton")
    espUsreBtn.Size             = UDim2.new(0.5, -2, 1, 0)
    espUsreBtn.BackgroundColor3 = C.TabActive
    espUsreBtn.TextColor3       = Color3.new(1, 1, 1)
    espUsreBtn.Text             = "Username"
    espUsreBtn.Font             = Enum.Font.GothamBold
    espUsreBtn.TextSize         = 10
    espUsreBtn.BorderSizePixel  = 0
    espUsreBtn.LayoutOrder      = 1
    espUsreBtn.ZIndex           = 53
    espUsreBtn.Parent           = espNameRow
    addCorner(espUsreBtn, UDim.new(0, 5))
    addStroke(espUsreBtn, C.Stroke, 1)

    local espDisplayBtn = Instance.new("TextButton")
    espDisplayBtn.Size             = UDim2.new(0.5, -2, 1, 0)
    espDisplayBtn.BackgroundColor3 = C.BtnOff
    espDisplayBtn.TextColor3       = C.SubText
    espDisplayBtn.Text             = "Display Name"
    espDisplayBtn.Font             = Enum.Font.GothamBold
    espDisplayBtn.TextSize         = 10
    espDisplayBtn.BorderSizePixel  = 0
    espDisplayBtn.LayoutOrder      = 2
    espDisplayBtn.ZIndex           = 53
    espDisplayBtn.Parent           = espNameRow
    addCorner(espDisplayBtn, UDim.new(0, 5))
    addStroke(espDisplayBtn, C.Stroke, 1)

    local function applyESPNameMode()
        if settingsUsreOn and settingsDisplayOn then
            espNameMode = "displayname"
        elseif settingsUsreOn then
            espNameMode = "username"
        elseif settingsDisplayOn then
            espNameMode = "displayonly"
        else
            settingsUsreOn = true
            espNameMode    = "username"
        end
    end

    local function refreshESPBtn(btn, isActive)
        TweenService:Create(btn, TweenInfo.new(0.13), {
            BackgroundColor3 = isActive and C.TabActive or C.BtnOff
        }):Play()
        btn.TextColor3 = isActive and Color3.new(1,1,1) or C.SubText
    end

    espUsreBtn.MouseButton1Click:Connect(function()
        if settingsUsreOn and not settingsDisplayOn then return end  -- must keep at least one on
        settingsUsreOn = not settingsUsreOn
        refreshESPBtn(espUsreBtn, settingsUsreOn)
        applyESPNameMode()
    end)

    espDisplayBtn.MouseButton1Click:Connect(function()
        if settingsDisplayOn and not settingsUsreOn then return end  -- must keep at least one on
        settingsDisplayOn = not settingsDisplayOn
        refreshESPBtn(espDisplayBtn, settingsDisplayOn)
        applyESPNameMode()
    end)

    refreshESPBtn(espUsreBtn,    settingsUsreOn)
    refreshESPBtn(espDisplayBtn, settingsDisplayOn)
    applyESPNameMode()

    -- Settings panel open/close logic
    local settingsPanelOpen = false

    closeSettingsPanel = function()
        settingsPanelOpen = false
        SettingsPanel.Visible = false
        TweenService:Create(SettingsBtn, TweenInfo.new(0.13), {
            BackgroundColor3 = Color3.fromRGB(55, 55, 80)
        }):Play()
    end

    local function openSettingsPanel()
        settingsPanelOpen = true
        SettingsPanel.Position = UDim2.new(
            MainFrame.Position.X.Scale,
            MainFrame.Position.X.Offset - SP_W - 8,
            MainFrame.Position.Y.Scale,
            MainFrame.Position.Y.Offset
        )
        SettingsPanel.Visible = true
        TweenService:Create(SettingsBtn, TweenInfo.new(0.13), {
            BackgroundColor3 = Color3.fromRGB(0, 130, 255)
        }):Play()
    end

    SettingsBtn.MouseButton1Click:Connect(function()
        if settingsPanelOpen then closeSettingsPanel() else openSettingsPanel() end
    end)
    SPCloseBtn.MouseButton1Click:Connect(closeSettingsPanel)
end

