-- Side panel drag
local sideDragging, sideDragStart, sidePanelStartPos
SideTitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        sideDragging = true; sideDragStart = input.Position; sidePanelStartPos = SidePanel.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if sideDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - sideDragStart
        SidePanel.Position = UDim2.new(
            sidePanelStartPos.X.Scale, sidePanelStartPos.X.Offset + delta.X,
            sidePanelStartPos.Y.Scale, sidePanelStartPos.Y.Offset + delta.Y
        )
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then sideDragging = false end
end)

