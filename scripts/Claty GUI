-- ────────────────────────────────────────────────────────────────
--  TAB SWITCHING
-- ────────────────────────────────────────────────────────────────
local function switchTab(tabNum)
    Page1.Visible = (tabNum == 1)
    Page2.Visible = (tabNum == 2)
    Tab1Btn.BackgroundColor3 = tabNum == 1 and C.TabActive or C.TabInactive
    Tab1Btn.TextColor3       = tabNum == 1 and Color3.new(1,1,1) or C.SubText
    Tab2Btn.BackgroundColor3 = tabNum == 2 and C.TabActive or C.TabInactive
    Tab2Btn.TextColor3       = tabNum == 2 and Color3.new(1,1,1) or C.SubText
end

Tab1Btn.MouseButton1Click:Connect(function() switchTab(1) end)
Tab2Btn.MouseButton1Click:Connect(function() switchTab(2) end)

-- ────────────────────────────────────────────────────────────────
--  TOGGLE GUI VISIBILITY  (RightShift)
--  Ignoring processed because ShiftLock marks RightShift as processed=true
-- ────────────────────────────────────────────────────────────────
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.RightShift then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

-- ================================================================
--  CHARACTER ADDED — Re-apply active features after respawn
--  Order: 1) new Character spawns → 2) wait 1s → 3) re-apply
-- ================================================================
charAddedConn = LocalPlayer.CharacterAdded:Connect(function(newChar)
    -- Clear stale fly references (destroyed with old character)
    flyBodyVel   = nil
    flyBodyGyro  = nil
    activeTpTool = nil

    task.wait(1)

    -- Re-apply Fly
    if flyIsActive then
        disableAllFly()
        task.wait()
        local box = featureStates["fly"] and featureStates["fly"].getBox and featureStates["fly"].getBox()
        local v   = box and tonumber(box.Text) or flySpeedValue
        if     settingsFlyType == "normal"  then enableNormalFly(v / 50)
        elseif settingsFlyType == "cframe"  then enableCFly(v)
        elseif settingsFlyType == "vehicle" then enableVehicleFly(v / 50)
        end
    end

    -- Re-apply Walk Speed
    if speedIsActive then
        local box = featureStates["walkspeed"] and featureStates["walkspeed"].getBox and featureStates["walkspeed"].getBox()
        local v   = box and tonumber(box.Text) or walkSpeedValue
        if settingsWalkSpeed == "loop" then enableLoopSpeed(v) else applyNormalSpeed(v) end
    end

    -- Re-apply Jump Power
    if jumpIsActive then
        local box = featureStates["jumppower"] and featureStates["jumppower"].getBox and featureStates["jumppower"].getBox()
        local v   = box and tonumber(box.Text) or jumpPowerValue
        if settingsJumpPower == "loop" then enableLoopJump(v) else applyNormalJump(v) end
    end

    -- Re-apply Infinite Jump
    if infJumpIsActive then
        disableInfJump()
        if settingsInfJump == "fly" then enableFlyInfJump() else enableNormalInfJump() end
    end

    -- Re-apply Noclip
    if featureStates["noclip"] and featureStates["noclip"].isOn() then
        disableNoclip()
        enableNoclip()
    end

    -- Re-apply Teleport Tool
    if tpToolEnabled then
        local backpack = LocalPlayer:WaitForChild("Backpack", 10)
        if backpack then spawnTpToolInBackpack(backpack) end
    end

    -- Re-apply Invisibility
    if invisEnabled then
        invisCurrentSeat = nil
        invisEnabled     = false
        task.wait(0.3)
        enableInvis()
    end

    -- Anti-Kill: handled automatically by akState.charConn → akSetupCharacter
end)

switchTab(1)
print("[Claty GUI] Loaded — RightShift to toggle visibility")
